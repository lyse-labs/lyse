{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing on the scoring engine (#104). Scoped to the score files — the moat's trust-bearing core. perTest coverage keeps runtime tractable. See docs/architecture/reliability.md.",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "reporters": ["clear-text", "progress", "json"],
  "jsonReporter": { "fileName": "reports/mutation/mutation.json" },
  "coverageAnalysis": "perTest",
  "concurrency": 4,
  "timeoutMS": 20000,
  "mutate": [
    "src/scorer.ts",
    "src/reliability/score/formula-v1.ts",
    "src/reliability/score/grace.ts",
    "src/reliability/grade.ts"
  ],
  "thresholds": { "high": 90, "low": 85, "break": 85 }
}
