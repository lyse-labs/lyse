# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Stray compiled output from a local `tsc` run next to its .ts source
packages/core/validation/*.js
packages/core/validation/*.js.map

# Test artifacts
coverage/
.nyc_output/

# Environment
.env*

# Credential / key material (defense in depth — none should ever be committed)
*.pem
*.key
*.p12
id_rsa*

# Editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Lyse runtime
/report/
.lyse/
.lyse-cache/

# Test fixture artifacts (per-test runs)
packages/core/fixtures/**/.lyse/

# Local agent state
.claude/*
!.claude/skills/
.claude/settings.local.json
.worktrees/

# Stryker mutation testing
.stryker-tmp/
packages/core/reports/

# golden-corpus fetch cache (third-party sources, never committed)
lyse-golden-corpus/

# SDD scratch (subagent-driven working files)
.superpowers/
# Backup files
*.bak

# Wrangler / Miniflare local dev state (regenerable)
.wrangler/
.color-harvest/

# Measurement campaign — cloned benchmark corpus (pinned SHAs, reproducible)
.bench-corpus/
